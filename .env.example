# Base de données PostgreSQL (Neon ou autre)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth – Authentification admin
# Générer un secret aléatoire : openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-random-secret-in-production"

# URL publique du site (utilisée par NextAuth et les redirections)
NEXTAUTH_URL="http://localhost:3000"

# URL publique du site (utilisée pour les liens absolus, sitemap, Stripe redirect)
NEXT_PUBLIC_SITE_URL="https://hotelducommercebellegarde.vercel.app"

# Stripe – Paiement en ligne
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
